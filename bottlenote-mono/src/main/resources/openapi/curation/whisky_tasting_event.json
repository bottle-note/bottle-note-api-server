                "comment": {
                  "type": "string",
                  "description": "위스키 기대평",
                  "example": "셰리 캐스크 입문용으로 추천",
                  "maxLength": 500,
                  "x-field-style": "long-text",
                  "x-display-name": "위스키 기대평",
                  "nullable": true
                }
              },
              "required": [
                "source",
                "alcohol"
              ]
            }
          }

            "description": "참가비",
            "example": 75000,
            "x-field-style": "plain-number",
            "x-display-name": "참가비(1인당)"
          },
          "capacity": {
            "type": "integer",
            "minimum": 1,
            "maximum": 999,
            "description": "총 모집 인원수",
            "example": 20,
            "x-field-style": "plain-number",
            "x-display-name": "총 모집 인원수"
          },
          "applicationLink": {

                        "셰리",
                        "건포도",
                        "오크"
                      ],
                      "maxItems": 12,
                      "items": {
                        "type": "string",
                        "minLength": 1,
                        "maxLength": 30
                      },
                      "x-field-style": "tag-list",
                      "x-display-name": "테이스팅 태그",
                      "x-ui-orderable": true
                    }
                  },
                  "required": [
                    "korName",
                    "selectedTags"

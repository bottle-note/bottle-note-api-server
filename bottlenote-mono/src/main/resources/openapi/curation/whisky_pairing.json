        "x-field-style": "alcohol-card",
        "x-display-name": "위스키",
        "properties": {
          "source": {
            "type": "string",
            "enum": [
              "BOTTLE_NOTE",
              "MANUAL"
            ],
            "description": "위스키 데이터 출처",
            "example": "BOTTLE_NOTE"
          },
          "alcohol": {

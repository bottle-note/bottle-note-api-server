{
  "openapi": "3.0.3",
  "info": {
    "title": "위스키 페어링",
    "description": "위스키 1건과 그 위스키에 어울리는 페어링 음식 N개를 묶어 소개하는 큐레이션.",
    "version": "2.0.0"
  },
  "x-curation": {
    "code": "WHISKY_PAIRING",
    "hydratorKey": "alcohol",
    "container": "array"
  },
  "paths": {},
